# Augur environment configuration
# Copy to .env and fill in values before running.
# Never commit the .env file.

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string for the application
DATABASE_URL=postgresql+asyncpg://augur:changeme@db:5432/augur
# Postgres credentials (used by docker-compose to initialise the DB)
POSTGRES_USER=augur
POSTGRES_PASSWORD=changeme
POSTGRES_DB=augur

# ── OpenRouter API keys ───────────────────────────────────────────────────────
# Main key — used by the signal pipeline (ingestion, extraction, anchoring,
# disconfirmation). Model access is not restricted on this key.
OPENROUTER_API_KEY=sk-or-v1-...

# Free-tier key — reserved exclusively for the conversation layer.
# Restrict this key on the OpenRouter dashboard to free-tier models only.
OPENROUTER_FREE_TIER_API_KEY=sk-or-v1-...

# ── Langfuse ──────────────────────────────────────────────────────────────────
# LLM observability. Langfuse runs on the same VPS.
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── SearXNG ───────────────────────────────────────────────────────────────────
# Meta-search instance running on the same VPS.
SEARXNG_URL=http://searxng:8080

# ── Object storage (backups) ──────────────────────────────────────────────────
# Hetzner Object Storage or Backblaze B2 (S3-compatible).
OBJECT_STORAGE_ENDPOINT=https://fsn1.your-objectstorage.com
OBJECT_STORAGE_BUCKET=augur-backups
OBJECT_STORAGE_ACCESS_KEY=...
OBJECT_STORAGE_SECRET_KEY=...
OBJECT_STORAGE_REGION=eu-central

# ── Cost / budget ─────────────────────────────────────────────────────────────
# Daily LLM spend cap for the main pipeline key (USD).
# The LLM client will refuse calls once this is exceeded.
DAILY_LLM_BUDGET_USD=5.00

# ── Application ──────────────────────────────────────────────────────────────
AUGUR_ENV=development
LOG_LEVEL=INFO
# Override to "production" to switch to JSON-only log output
LOG_FORMAT=text
